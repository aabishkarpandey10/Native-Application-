# Single source of truth — edit this file, then run: npm run setup:env
# Full stack dev (backend + Expo web): npm run dev
# Docker (API + web): npm run docker:setup && npm run docker:up
# Full stack (Postgres + Redis + RabbitMQ): docker compose -f docker-compose.full.yml up

# Expo app → Express API
#
# DEV (Expo Go): localhost is OK — the app auto-rewrites to your PC's LAN IP.
# RELEASE APK: must be set BEFORE `npm run build:android:release` — baked into the bundle.
#   Same Wi‑Fi testing:  EXPO_PUBLIC_API_URL=http://192.168.x.x:3000  (your PC IP from ipconfig)
#   Production / Play:    EXPO_PUBLIC_API_URL=https://your-api.example.com
# EAS cloud builds: eas env:create --environment production --name EXPO_PUBLIC_API_URL --value https://...
EXPO_PUBLIC_API_URL=http://localhost:3000
# Log successful API requests in dev; failures always log in release (logcat). Set true to log all requests in APK.
EXPO_PUBLIC_API_DEBUG=false
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SENTRY_DSN=

# Backend — get a free API key at https://opendata.transport.nsw.gov.au/
TFNSW_API_KEY=your_tfnsw_api_key_here
# Demo timetables when TfNSW is unreachable — off by default (set true for offline local dev only).
ALLOW_MOCK_DATA=false
# Log every HTTP request on the Express server (useful during integration testing).
API_REQUEST_LOG=false
PORT=3000
HOST=0.0.0.0
# Public URL shown in logs (optional): https://your-api.onrender.com
PUBLIC_URL=
# Comma-separated browser origins for CORS (native apps ignore CORS). Use * to allow all web origins.
CORS_ORIGIN=
NODE_ENV=development
# Docker local runtime (overrides placeholder JWT_SECRET in .env for compose)
DOCKER_JWT_SECRET=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Auth (change in production)
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# Redis cache (enable with docker-compose.full.yml)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10

# Real-time polling
TFNSW_POLL_MS=30000
CACHE_TTL_SECONDS=25
STALE_CACHE_TTL_SECONDS=300
WS_HEARTBEAT_MS=25000

# Admin panel — http://localhost:3000/admin (disabled in production unless ENABLE_ADMIN=true)
ENABLE_ADMIN=false
ADMIN_PASSWORD=admin123
ADMIN_TOKEN=sydney-transit-admin-dev

# App feature flags (EAS production builds set these via eas.json)
EXPO_PUBLIC_ENABLE_ADMIN=false
EXPO_PUBLIC_ENABLE_ASSISTANT=false

# TfNSW rate limiting (per station, milliseconds)
TFNSW_MIN_INTERVAL_MS=8000
TFNSW_FETCH_TIMEOUT_MS=12000
TFNSW_FULLDAY_TIMEOUT_MS=20000
TFNSW_TRIP_TIMEOUT_MS=8000
TFNSW_FULLDAY_TRIP_TIMEOUT_MS=20000
