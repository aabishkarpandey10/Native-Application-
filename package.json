{
  "name": "nativeapplication",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.106.1",
    "@tanstack/react-query": "^5.100.14",
    "adm-zip": "^0.5.17",
    "expo": "^54.0.35",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "gtfs-realtime-bindings": "^2.0.0",
    "lucide-react-native": "^1.16.0",
    "nativewind": "^4.2.4",
    "protobufjs": "^8.4.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "typescript": "~5.9.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^54.0.11",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "metro-runtime": "^0.84.4",
    "pdf-parse": "^2.4.5",
    "tailwindcss": "^3.4.19"
  },
  "scripts": {
    "start": "node backend/server.js",
    "setup:env": "node scripts/setup-env.mjs",
    "prebackend": "node scripts/setup-env.mjs",
    "postinstall": "node scripts/install-backend.mjs",
    "backend": "node backend/server.js",
    "backend:stop": "node scripts/stop-backend.js",
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/setup-env.mjs && node scripts/install-backend.mjs && npx tsc --noEmit && npx expo export --platform web && node scripts/patch-web-dist.mjs",
    "build:vercel": "node scripts/verify-vercel-env.mjs && npx tsc --noEmit && npx expo export --platform web && node scripts/patch-web-dist.mjs",
    "build:api": "node scripts/install-backend.mjs && cd backend && npm run build",
    "build:all": "npm run setup:env && npm run build && node --check backend/server.js",
    "prebuild:native": "expo prebuild --clean",
    "build:android": "eas build --platform android --profile preview --non-interactive",
    "build:ios": "eas build --platform ios --profile preview",
    "build:ios:simulator": "eas build --platform ios --profile preview-simulator --non-interactive",
    "build:mobile": "eas build --platform all --profile preview",
    "build:android:release": "node scripts/build-android-release.mjs",
    "build:ios:release": "node scripts/build-ios-release.mjs",
    "build:ios:release:store": "node scripts/build-ios-release.mjs --profile production",
    "verify:release-api": "node scripts/verify-release-api.mjs",
    "verify:live": "node scripts/verify-live-integration.mjs",
    "build:android:local": "expo run:android --variant release",
    "build:ios:local": "expo run:ios --configuration Release",
    "verify": "node scripts/setup-env.mjs && node scripts/install-backend.mjs && npx tsc --noEmit && node scripts/check-stack.mjs",
    "compile": "npx tsc --noEmit",
    "compile:all": "npm run compile && npx expo export --platform web --output-dir .cache/expo-export-web",
    "seed:network-map": "node scripts/seed-network-map.mjs",
    "sync:train-network-gtfs": "node scripts/sync-train-network-gtfs.mjs",
    "sync:train-network": "node scripts/sync-train-network.mjs",
    "merge:train-gtfs-timetables": "node scripts/merge-train-gtfs-timetables.mjs",
    "sync:train": "node scripts/sync-train-network-gtfs.mjs && node scripts/sync-train-network.mjs && node scripts/import-train-timetables.mjs T1 T2 T3 T4 T5 T6 T7 T8 T9 && node scripts/merge-train-gtfs-timetables.mjs",
    "sync:transit-networks": "node scripts/sync-transit-networks.mjs",
    "sync:ferry-network": "node scripts/sync-ferry-network.mjs",
    "sync:bus-network": "node scripts/sync-bus-network.mjs",
    "sync:light-rail-network": "node scripts/sync-light-rail-network.mjs",
    "sync:metro-network": "node scripts/sync-metro-network.mjs",
    "merge:metro-gtfs-timetables": "node scripts/merge-metro-gtfs-timetables.mjs",
    "sync:metro": "node scripts/sync-metro-network.mjs && node scripts/merge-metro-gtfs-timetables.mjs",
    "merge:lr-gtfs-timetables": "node scripts/merge-lr-gtfs-timetables.mjs",
    "sync:light-rail": "node scripts/sync-light-rail-network.mjs && node scripts/import-train-timetables.mjs L1 L2 L3 && node scripts/merge-lr-gtfs-timetables.mjs",
    "merge:bus-gtfs-timetables": "node scripts/merge-bus-gtfs-timetables.mjs",
    "sync:bus": "node scripts/sync-bus-network.mjs && node scripts/merge-bus-gtfs-timetables.mjs",
    "sync:all-timetables": "node scripts/import-train-timetables.mjs && node scripts/merge-train-gtfs-timetables.mjs && node scripts/merge-lr-gtfs-timetables.mjs && node scripts/merge-metro-gtfs-timetables.mjs && node scripts/sync-bus-network.mjs && node scripts/merge-bus-gtfs-timetables.mjs",
    "import:t1-timetable": "node scripts/import-train-timetables.mjs T1",
    "import:timetables": "node scripts/import-train-timetables.mjs",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8085",
    "serve:web": "npx serve@14 dist -l 8085",
    "lint": "eslint .",
    "docker:setup": "node scripts/setup-env.mjs",
    "docker:build": "docker compose build",
    "docker:up": "node scripts/docker-up.mjs",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:full": "docker compose -f docker-compose.full.yml up --build -d",
    "docker:full:down": "docker compose -f docker-compose.full.yml down",
    "docker:api": "node scripts/docker-up.mjs --api-only",
    "docker:api:build": "docker compose -f docker-compose.api.yml build",
    "docker:check": "node scripts/docker-check.mjs",
    "docker:repair": "node scripts/docker-repair.mjs"
  },
  "private": true,
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  }
}
